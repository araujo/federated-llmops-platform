# Federated LLMOps Platform - API Service
# Build from repo root: docker build -f Dockerfile.api -t llmops-api .
FROM python:3.12-slim

WORKDIR /app

# Install packages in order (retrieval -> prompts -> orchestration -> tools -> api)
COPY packages/prompts /app/packages/prompts
COPY packages/retrieval /app/packages/retrieval
COPY packages/orchestration /app/packages/orchestration
COPY packages/tools /app/packages/tools
RUN pip install --no-cache-dir /app/packages/prompts /app/packages/retrieval
RUN pip install --no-cache-dir /app/packages/orchestration /app/packages/tools

# Copy evals (for python -m evals.run)
COPY evals /app/evals

# Install API
COPY apps/api/pyproject.toml apps/api/
COPY apps/api/api apps/api/api/
COPY apps/api/main.py apps/api/
COPY apps/api/tests apps/api/tests/
WORKDIR /app/apps/api
RUN pip install --no-cache-dir .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
